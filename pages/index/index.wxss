/* pages/index/index.wxss */
.container {
  padding-bottom: 120rpx;
}

/* 统计卡片 */
.stats-card {
  margin: 30rpx 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.stats-row:last-child {
  margin-bottom: 0;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-label {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
}

.stats-value.income {
  color: #27ae60;
}

.stats-value.expense {
  color: #e74c3c;
}

/* 记账按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 160rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.income-btn {
  background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
  color: #ffffff;
}

.expense-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #ec7063 100%);
  color: #ffffff;
}

.action-icon {
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 32rpx;
}

/* 最近记录 */
.recent-records {
  margin: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.month-selector {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.month-text {
  font-size: 28rpx;
  color: #666666;
  margin-right: 10rpx;
}

.month-arrow {
  font-size: 20rpx;
  color: #999999;
}

.records-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  position: relative;
  overflow: hidden;
}

.record-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  transition: transform 0.3s;
  position: relative;
  z-index: 1;
}

.record-main.swiped {
  transform: translateX(-150rpx);
}

.record-item:last-child .record-main {
  border-bottom: none;
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-category {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-amount {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.record-amount.income {
  color: #27ae60;
}

.record-amount.expense {
  color: #e74c3c;
}

.record-note {
  font-size: 24rpx;
  color: #999999;
}

.record-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 150rpx;
  background-color: #e74c3c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transform: translateX(100%);
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.category-tag {
  padding: 15rpx 30rpx;
  background-color: #f5f5f5;
  color: #666666;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.category-tag.active {
  background-color: #27ae60;
  color: #ffffff;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666666;
}

.confirm-btn {
  background-color: #27ae60;
  color: #ffffff;
}

/* 月份选择器 */
.month-picker-content {
  width: 500rpx;
  padding: 0;
}

.month-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.month-picker-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #27ae60;
  font-weight: bold;
}

.month-picker-display {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.month-picker-footer {
  padding: 30rpx 40rpx;
}

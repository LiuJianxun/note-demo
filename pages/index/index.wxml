<view class="top-navbar" style="height: {{navBarMetrics.navBarHeight}}px; padding-top: {{navBarMetrics.statusBarHeight}}px;">
  <view class="top-navbar__inner" style="height: {{navBarMetrics.titleBarHeight}}px; padding-left: {{navBarMetrics.leftPadding}}px; padding-right: {{navBarMetrics.rightPadding}}px;">
    <view class="top-navbar__brand" style="max-width: {{navBarMetrics.contentWidth}}px;">
      <text class="top-navbar__title">鱼籽记账</text>
    </view>
  </view>
</view>

<view class="page-body">
<view class="container">
  <view class="daily-card">
    <view class="daily-top">
      <view class="daily-info">
        <text class="daily-time">{{currentTime}}</text>
      </view>
      <view class="weather-pill" bindtap="showWeatherDebug">{{weatherText}}</view>
    </view>
    <view class="daily-mood-wrap">
      <text class="daily-mood">{{animatedMoodText}}</text>
      <text class="daily-mood-cursor">|</text>
    </view>
  </view>

  <view class="stats-card card">
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-label">今日收入</text>
        <text class="stats-value income">+{{todayIncome}}</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">今日支出</text>
        <text class="stats-value expense">-{{todayExpense}}</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-label">本月收入</text>
        <text class="stats-value income">+{{monthIncome}}</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">本月支出</text>
        <text class="stats-value expense">-{{monthExpense}}</text>
      </view>
    </view>
  </view>

  <view class="action-buttons">
    <view class="action-btn income-btn" bindtap="showIncomeModal">
      <text class="action-icon">+</text>
      <text class="action-text">记收入</text>
    </view>
    <view class="action-btn expense-btn" bindtap="showExpenseModal">
      <text class="action-icon">-</text>
      <text class="action-text">记支出</text>
    </view>
  </view>

  <view class="recent-records">
    <view class="section-header">
      <view class="section-title">最近记录</view>
      <view class="month-selector" bindtap="showMonthPicker">
        <text class="month-text">{{displayMonth}}</text>
        <text class="month-arrow">▼</text>
      </view>
    </view>

    <view class="records-list" wx:if="{{recentGroups.length > 0}}">
      <view class="record-group" wx:for="{{recentGroups}}" wx:key="date">
        <view class="group-header">
          <view class="group-date">{{item.title}}</view>
          <view class="group-summary">{{item.summaryText}}</view>
        </view>

        <view class="record-item" wx:for="{{item.records}}" wx:key="id">
          <view
            class="record-main {{currentSwipeId === item.idText ? 'swiped' : ''}}"
            bindtouchstart="onTouchStart"
            bindtouchmove="onTouchMove"
            bindtouchend="onTouchEnd"
            data-id="{{item.idText}}">
            <view class="record-left">
              <view class="record-badge {{item.type === 'income' ? 'income-badge' : 'expense-badge'}}">
                <text class="record-badge-icon" wx:if="{{item.hasIcon}}">{{item.iconText}}</text>
                <text class="record-badge-text" wx:else>{{item.category}}</text>
              </view>
              <view class="record-content">
                <view class="record-title">{{item.titleText}}</view>
                <view class="record-detail">{{item.detailText}}</view>
              </view>
            </view>
            <view class="record-right">
              <view class="record-amount {{item.type === 'income' ? 'income' : 'expense'}}">{{item.amountText}}</view>
            </view>
          </view>
          <view class="record-delete" bindtap="confirmDelete" data-id="{{item.idText}}">删除</view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:else>暂无记录，去记一笔吧。</view>
  </view>
</view>
</view>

<view class="modal" wx:if="{{showAuthModal}}" catchtap="hideAuthModal">
  <view class="modal-content auth-content" catchtap="stopPropagation">
    <view class="modal-title">授权微信信息</view>
    <view class="auth-desc">完成头像和昵称授权后，才可以继续记账。</view>

    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="auth-avatar-image" wx:if="{{authAvatarUrl}}" src="{{authAvatarUrl}}" mode="aspectFill" />
      <view class="auth-avatar-placeholder" wx:else>选择头像</view>
    </button>

    <view class="form-item">
      <text class="form-label">微信昵称</text>
      <input
        class="form-input"
        type="nickname"
        placeholder="请输入微信昵称"
        value="{{authNickName}}"
        bindinput="onNickNameInput"
        bindblur="onNickNameInput" />
    </view>

    <view class="modal-buttons">
      <view class="modal-btn cancel-btn" bindtap="hideAuthModal">取消</view>
      <view class="modal-btn confirm-btn" bindtap="confirmUserInfo">授权并继续</view>
    </view>
  </view>
</view>

<view class="modal" wx:if="{{showMonthPicker}}" catchtap="hideMonthPicker">
  <view class="modal-content month-picker-content" catchtap="stopPropagation">
    <view class="month-picker-header">
      <view class="month-picker-btn" bindtap="prevMonth">‹</view>
      <view class="month-picker-display">{{displayMonth}}</view>
      <view class="month-picker-btn" bindtap="nextMonth">›</view>
    </view>
    <view class="month-picker-footer">
      <view class="modal-btn confirm-btn" bindtap="hideMonthPicker">确定</view>
    </view>
  </view>
</view>

<view class="modal" wx:if="{{showModal}}" catchtap="hideModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">{{modalType === 'income' ? '记收入' : '记支出'}}</view>

    <view class="form-item">
      <text class="form-label">金额</text>
      <input class="form-input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="form-item">
      <text class="form-label">分类</text>
      <scroll-view class="category-scroll" scroll-y enhanced show-scrollbar="false">
        <view class="category-list">
          <view
            class="category-tag {{selectedCategory === item ? 'active' : ''}}"
            wx:for="{{categories}}"
            wx:key="index"
            bindtap="selectCategory"
            data-category="{{item}}">
            {{item}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="可选，补充说明" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <view class="modal-buttons">
      <view class="modal-btn cancel-btn" bindtap="hideModal">取消</view>
      <view class="modal-btn confirm-btn" bindtap="saveRecord">确定</view>
    </view>
  </view>
</view>

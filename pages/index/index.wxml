<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部统计卡片 -->
  <view class="stats-card card">
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-label">今日收入</text>
        <text class="stats-value income">+{{todayIncome}}</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">今日支出</text>
        <text class="stats-value expense">-{{todayExpense}}</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-label">本月收入</text>
        <text class="stats-value income">+{{monthIncome}}</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">本月支出</text>
        <text class="stats-value expense">-{{monthExpense}}</text>
      </view>
    </view>
  </view>

  <!-- 记账按钮 -->
  <view class="action-buttons">
    <view class="action-btn income-btn" bindtap="showIncomeModal">
      <text class="action-icon">+</text>
      <text class="action-text">记收入</text>
    </view>
    <view class="action-btn expense-btn" bindtap="showExpenseModal">
      <text class="action-icon">-</text>
      <text class="action-text">记支出</text>
    </view>
  </view>

  <!-- 最近记录 -->
  <view class="recent-records">
    <view class="section-header">
      <view class="section-title">最近记录</view>
      <view class="month-selector" bindtap="showMonthPicker">
        <text class="month-text">{{displayMonth}}</text>
        <text class="month-arrow">▼</text>
      </view>
    </view>
    <view class="records-list" wx:if="{{recentRecords.length > 0}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id">
        <view
          class="record-main {{currentSwipeId === item.id ? 'swiped' : ''}}"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
          data-id="{{item.id}}">
          <view class="record-left">
            <view class="record-category">{{item.category}}</view>
            <view class="record-time">{{item.time}}</view>
          </view>
          <view class="record-right">
            <view class="record-amount {{item.type === 'income' ? 'income' : 'expense'}}">
              {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
            </view>
            <view class="record-note" wx:if="{{item.note}}">{{item.note}}</view>
          </view>
        </view>
        <view class="record-delete" bindtap="confirmDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>
    <view class="empty-tip" wx:else>暂无记录，快去记一笔吧~</view>
  </view>
</view>

<!-- 月份选择器弹窗 -->
<view class="modal" wx:if="{{showMonthPicker}}" catchtap="hideMonthPicker">
  <view class="modal-content month-picker-content" catchtap="stopPropagation">
    <view class="month-picker-header">
      <view class="month-picker-btn" bindtap="prevMonth">‹</view>
      <view class="month-picker-display">{{displayMonth}}</view>
      <view class="month-picker-btn" bindtap="nextMonth">›</view>
    </view>
    <view class="month-picker-footer">
      <view class="modal-btn confirm-btn" bindtap="hideMonthPicker">确定</view>
    </view>
  </view>
</view>

<!-- 记账弹窗 -->
<view class="modal" wx:if="{{showModal}}" catchtap="hideModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">{{modalType === 'income' ? '记收入' : '记支出'}}</view>

    <!-- 金额输入 -->
    <view class="form-item">
      <text class="form-label">金额</text>
      <input class="form-input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <!-- 分类选择 -->
    <view class="form-item">
      <text class="form-label">分类</text>
      <view class="category-list">
        <view
          class="category-tag {{selectedCategory === item ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="index"
          bindtap="selectCategory"
          data-category="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <!-- 备注输入 -->
    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="请输入备注（可选）" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <!-- 按钮 -->
    <view class="modal-buttons">
      <view class="modal-btn cancel-btn" bindtap="hideModal">取消</view>
      <view class="modal-btn confirm-btn" bindtap="saveRecord">确定</view>
    </view>
  </view>
</view>

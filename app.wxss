/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局按钮样式 */
.btn-primary {
  background-color: #27ae60;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx;
  text-align: center;
}

.btn-danger {
  background-color: #e74c3c;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx;
  text-align: center;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

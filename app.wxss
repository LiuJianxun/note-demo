/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局按钮样式 */
.btn-primary {
  background-color: #27ae60;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx;
  text-align: center;
}

.btn-danger {
  background-color: #e74c3c;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx;
  text-align: center;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.top-navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, #f6c93a 0%, #ffd859 46%, #ffe98a 100%);
  box-shadow: 0 8rpx 20rpx rgba(214, 165, 20, 0.12);
}

.top-navbar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.top-navbar__brand {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 0;
  padding: 0 12rpx;
  box-sizing: border-box;
  flex-wrap: nowrap;
  overflow: hidden;
}

.top-navbar__logo {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 28%, #ffe9a1 0%, #f2c44c 42%, #c88a16 100%);
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 248, 205, 0.75),
    inset 0 -6rpx 10rpx rgba(138, 82, 0, 0.22),
    0 8rpx 18rpx rgba(157, 102, 6, 0.16);
  border: 2rpx solid rgba(126, 77, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.top-navbar__logo::before {
  content: '';
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(126, 77, 0, 0.2);
}

.top-navbar__logo::after {
  content: '';
  position: absolute;
  right: 13rpx;
  top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 248, 211, 0.78);
}

.top-navbar__logo-text {
  font-size: 26rpx;
  font-weight: 900;
  color: #7c4700;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 0 rgba(255, 248, 210, 0.45);
}

.top-navbar__title {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  color: #6a3a00;
  white-space: nowrap;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  text-shadow:
    0 1rpx 0 rgba(255, 247, 202, 0.92),
    0 2rpx 0 rgba(173, 108, 8, 0.2),
    0 0 10rpx rgba(255, 229, 139, 0.34),
    0 6rpx 12rpx rgba(128, 81, 7, 0.14);
}

.page-body {
  padding-top: 8rpx;
}
